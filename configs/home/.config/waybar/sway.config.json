[
    {
        "layer": "top",
        "modules-left": [
            "sway/workspaces",
            "custom/cpu",
            "custom/cpu-freq",
            "custom/ram",
            "sway/mode",
            "custom/temp",
            "custom/net"
        ],
        "modules-center": [
            "custom/clock"
        ],
        "modules-right": [
            "cava",
            "custom/playerctl",
            "tray",
            "sway/language",
            "pulseaudio",
            "idle_inhibitor",
            "network",
            "power-profiles-daemon",
            "battery"
        ],
        "sway/window": {
            "max-length": 50
