        "tray": {
            "icon-size": 21,
            "spacing": 10,
            "icons": {
                "easyeffects": "/usr/share/icons/hicolor/scalable/apps/com.github.wwmm.easyeffects-symbolic.svg",
                "РєРѕРЅС‚СѓСЂ.С‚РѕР»Рє": "/home/dmitriy.tikhomirov/desktop/owned/ktalk.png"
            }
        },
        "battery": {
            "interval": 3,
